# Copy this file to .env and fill in the values

# Google OAuth — get from https://console.cloud.google.com
# Authorized redirect URI to add: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT signing secret — any long random string
JWT_SECRET=change_this_to_a_long_random_string

# Session secret — any long random string
SESSION_SECRET=change_this_to_another_long_random_string

# URLs
FRONTEND_URL=http://localhost:5173
SERVER_URL=http://localhost:3001
PORT=3001

# Email (SMTP) — optional, logs to console if not set
# For Gmail: use App Password from https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="RelaxNow" <your_gmail@gmail.com>

# Azure Communication Services (production replacement for nodemailer)
# AZURE_COMMUNICATION_CONNECTION_STRING=

# Razorpay — get from https://dashboard.razorpay.com/app/keys
# Use test keys (rzp_test_...) for development
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
